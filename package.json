{
  "name": "acme-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "24.14.0"
  },
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "build": "next build",
    "clean": "git clean -xdf node_modules .next",
    "auth:generate": "pnpm dlx auth generate --config=src/libs/better-auth/auth.ts --output=src/server/db/schema/auth-schema-new.ts --yes",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/server/db/seed.ts",
    "dev": "next dev",
    "email:dev": "email dev --dir=src/emails --port=3001",
    "ui:add": "pnpm dlx shadcn@latest add",
    "format": "biome format --write .",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "SKIP_ENV_VALIDATION=1 next typegen && tsc --noEmit",
    "test": "bun test",
    "start": "node .next/standalone/server.js"
  },
  "dependencies": {
    "@base-ui/react": "1.3.0",
    "@better-auth/api-key": "1.6.1",
    "@better-auth/drizzle-adapter": "1.6.1",
    "@better-auth/passkey": "1.6.1",
    "@hono/zod-openapi": "1.2.1",
    "@hookform/resolvers": "5.2.2",
    "@kubiks/otel-drizzle": "2.1.0",
    "@kubiks/otel-resend": "1.1.0",
    "@neondatabase/serverless": "1.0.2",
    "@opentelemetry/api": "1.9.0",
    "@opentelemetry/api-logs": "0.211.0",
    "@opentelemetry/exporter-logs-otlp-http": "0.211.0",
    "@opentelemetry/exporter-metrics-otlp-http": "0.211.0",
    "@opentelemetry/resources": "2.5.0",
    "@opentelemetry/sdk-logs": "0.211.0",
    "@opentelemetry/sdk-metrics": "2.5.0",
    "@opentelemetry/semantic-conventions": "1.39.0",
    "@react-email/components": "1.0.11",
    "@scalar/hono-api-reference": "0.9.40",
    "@t3-oss/env-nextjs": "0.13.11",
    "@tanstack/react-hotkeys": "0.9.1",
    "@tanstack/react-query": "5.96.1",
    "@tanstack/react-query-devtools": "5.96.1",
    "@tanstack/react-table": "8.21.3",
    "@trpc/client": "11.16.0",
    "@trpc/server": "11.16.0",
    "@trpc/tanstack-react-query": "11.16.0",
    "@vercel/otel": "2.1.1",
    "better-all": "0.0.7",
    "better-auth": "1.6.1",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "date-fns": "4.1.0",
    "dotenv": "17.3.1",
    "drizzle-orm": "0.45.2",
    "drizzle-seed": "0.3.1",
    "flat": "6.0.1",
    "hono": "4.12.12",
    "hono-rate-limiter": "0.5.3",
    "input-otp": "1.4.2",
    "lucide-react": "0.563.0",
    "next": "16.2.3",
    "next-international": "1.3.1",
    "next-themes": "0.4.6",
    "nuqs": "2.8.9",
    "pg": "8.18.0",
    "pino": "10.3.1",
    "pino-opentelemetry-transport": "2.0.0",
    "pino-pretty": "13.1.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-error-boundary": "6.1.1",
    "react-hook-form": "7.72.0",
    "react-qr-code": "2.0.18",
    "resend": "6.10.0",
    "shadcn": "4.1.2",
    "sonner": "2.0.7",
    "superjson": "2.2.6",
    "tailwind-merge": "3.5.0",
    "tailwindcss": "4.2.2",
    "tw-animate-css": "1.4.0",
    "ua-parser-js": "2.0.9",
    "web-vitals": "5.1.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.11",
    "@electric-sql/pglite": "0.4.3",
    "@happy-dom/global-registrator": "20.8.9",
    "@react-email/preview-server": "5.2.10",
    "@tailwindcss/postcss": "4.2.2",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/bun": "1.3.11",
